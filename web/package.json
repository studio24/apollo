{
  "name": "apollo",
  "version": "1.0.0",
  "description": "npm scripts for building and watching Apollo",
  "scripts": {
    "css:mainsass:compressed": "node-sass --output-style=compressed --source-map=true web/assets/styles/styles.scss dist/assets/styles/styles.min.css",
    "css:mainsass:uncompressed": "node-sass web/assets/styles/styles.scss dist/assets/styles/styles.css",
    "css:sass": "npm-run-all --parallel css:mainsass:*",
    "css:autoprefixer": "autoprefixer-cli -d dist/assets/styles dist/assets/styles/*.css",
    "css": "npm-run-all --sequential css:sass css:copylibraries css:autoprefixer",
    "images:imagemin": "imagemin web/assets/images/* --out-dir=dist/assets/images",
    "images:svg": "svgo --folder=web/assets/svg --output=dist/assets/svg --disable='removeViewBox' | true",
    "images": "npm-run-all --parallel images:imagemin images:svg",
    "fonts": "shx cp -r web/assets/fonts/* dist/assets/fonts",
    "js:copylibraries": "shx cp -r web/assets/js/libraries/* dist/assets/js/libraries/ | true",
    "css:copylibraries": "shx cp -r web/assets/styles/libraries/* dist/assets/styles/libraries/ | true",
    "jsmain:babel:compressed": "babel web/assets/js/app.js --out-file dist/assets/js/app.min.js --minified --compact",
    "jsmain:babel:uncompressed": "babel web/assets/js/app.js --out-file dist/assets/js/app.js",
    "js": "npm-run-all --parallel js:copylibraries jsmain:babel:*",
    "postinstall": "shx mkdir -p web/assets/js/libraries && shx mkdir -p web/assets/images && shx mkdir -p web/assets/fonts",
    "build": "npm-run-all --parallel css images fonts js",
    "prebuild": "shx rm -rf dist && shx mkdir -p dist/assets/fonts && shx mkdir dist/assets/images && shx mkdir dist/assets/js && shx mkdir dist/assets/js/libraries && shx mkdir dist/assets/styles && shx mkdir dist/assets/styles/libraries && shx mkdir dist/assets/svg",
    "watch:css": "watch 'npm run css' web/assets/styles --interval=1",
    "watch:images:svg": "watch 'npm run images:svg' web/assets/svg --interval=1",
    "watch:images:imagemin": "watch 'npm run images:imagemin' web/assets/images --interval=1",
    "watch:fonts": "watch 'npm run fonts' web/assets/fonts --interval=1",
    "watch:css:copylibraries": "watch 'npm run css:copylibraries' web/assets/styles/libraries --interval=1",
    "watch:js:copylibraries": "watch 'npm run js:copylibraries' web/assets/js/libraries --interval=1",
    "watch:jsmainbabel:compressed": "watch 'npm run jsmain:babel:compressed' web/assets/js/ --ignoreDirectoryPattern=/libraries/.*/ --interval=1",
    "watch:jsmainbabel:uncompressed": "watch 'npm run jsmain:babel:uncompressed' web/assets/js/ --ignoreDirectoryPattern=/libraries/.*/ --interval=1",
    "watch": "npm-run-all --parallel watch:* watch:*:*"
  },
  "author": "Studio 24",
  "license": "ISC",
  "dependencies": {
    "autoprefixer-cli": "^1.0.0",
    "babel-cli": "^6.26.0",
    "imagemin-cli": "^3.0.0",
    "node-sass": "^4.9.0",
    "npm-run-all": "^4.1.3",
    "shx": "^0.2.2",
    "svgo": "^1.0.5",
    "watch": "^1.0.2"
  }
}
